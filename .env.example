APP_NAME=Malaria Triage AI
MODEL_PATH=model/malaria_resnet18.onnx
MODEL_VERSION=resnet18_v1

# Keep false for real ONNX inference. Set true only for local smoke tests without a model.
DEMO_MODE=false

INPUT_SIZE=224
POSITIVE_THRESHOLD=0.80
NEGATIVE_THRESHOLD=0.30

MAX_UPLOAD_MB=10
MAX_BATCH_IMAGES=20
ACCEPTED_MIME_TYPES=image/jpeg,image/png

MIN_IMAGE_WIDTH=128
MIN_IMAGE_HEIGHT=128
BLUR_THRESHOLD=100
MIN_CONTRAST=15
MIN_BRIGHTNESS=30
MAX_BRIGHTNESS=225

